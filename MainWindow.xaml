<Window x:Class="WindowsToolsLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Tools Launcher" Height="600" Width="520"
        Background="#2E2E2E" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Click a button to launch the tool"
                   FontSize="16" FontWeight="SemiBold" Margin="5,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel Name="ToolsWrapPanel" Orientation="Horizontal"/>
        </ScrollViewer>
    </Grid>
</Window>
