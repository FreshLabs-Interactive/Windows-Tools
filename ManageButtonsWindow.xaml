<Window x:Class="WindowsToolsLauncher.ManageButtonsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Custom Buttons" Height="300" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#2E2E2E" Foreground="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- List of custom tools -->
        <ListBox x:Name="ToolsListBox" Grid.Row="0"
                 Background="#3A3A3A" Foreground="White"
                 BorderBrush="#555" Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Width="120"/>
                        <TextBlock Text="{Binding Command}" Foreground="LightGray"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Add / Edit / Remove controls -->
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name row -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center"
                           Margin="0,0,5,5"/>
                <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"
                         Background="#3A3A3A" Foreground="White" BorderBrush="#555"/>

                <!-- Command/Path row with Browse button -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Command/Path:" VerticalAlignment="Center"
                           Margin="0,0,5,5"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CommandTextBox" Grid.Column="0"
                             Background="#3A3A3A" Foreground="White" BorderBrush="#555"/>
                    <Button Grid.Column="1" Content="Browse..." Width="60" Height="23"
                            Background="#555" Foreground="White" Click="BrowseButton_Click"
                            Margin="5,0,0,0"/>
                </Grid>
            </Grid>
            <TextBlock Text="Custom buttons will be colored BLUE" Foreground="#007ACC"
                        Width="207" FontWeight="SemiBold" FontSize="10" Height="15" HorizontalAlignment="left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button x:Name="AddButton" Content="Add" Width="60" Height="25"
                        Background="#555" Foreground="White" Click="AddButton_Click" Margin="0,0,5,0"/>
                <Button x:Name="UpdateButton" Content="Update" Width="60" Height="25"
                        Background="#555" Foreground="White" Click="UpdateButton_Click" Margin="0,0,5,0"/>
                <Button x:Name="RemoveButton" Content="Remove" Width="60" Height="25"
                        Background="#555" Foreground="White" Click="RemoveButton_Click" Margin="0,0,5,0"/>
                <Button x:Name="SaveCloseButton" Content="Save &amp; Close" Width="90" Height="25"
                        Background="#007ACC" Foreground="White" Click="SaveCloseButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>